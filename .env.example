# Provider selection: fake, openai, claude_code, gemini, kimi
MULTIBOT_PROVIDER=fake

# OpenAI-compatible GPT adapter
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# Claude Code CLI adapter
CLAUDE_CODE_COMMAND=claude

# Gemini adapter
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Kimi / Moonshot adapter
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.ai/v1/chat/completions

# Safety defaults
MULTIBOT_MAX_STEPS=6
MULTIBOT_TIMEOUT_SECONDS=30
MULTIBOT_MAX_PROMPT_CHARS=4000
MULTIBOT_EVENT_LOG=data/runs.sqlite
